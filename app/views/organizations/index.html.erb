<% content_for :title, "Git" %>

<%= header(title: "Git" , items: []) %>

<div class="home-page">
  <div class="organizations">
    <% @organizations.each_with_index do |organization, index| %> 
      <div class="organization">
        <%= image_tag "image#{index + 1}.png", loading: "lazy", class: "background-image" %>
        
        <div class="organization-details frosted-glass">
          <img src="<%= organization.avatar_url %>" loading="lazy">  

          <div class="organization-data">
            <p class="title"><%= organization.name %></p>
            <p class="description <%= "null-value" if organization.description.blank? %>"><%= organization.display_description %></p>
          </div>
        </div>

        <div class="repositories">
          <% organization.repositories.each do |repository| %>  
            <div class="repository frosted-glass">
              <p class="title"><%= repository.name %></p>
              <p class="description"><%= repository.display_description %></p>    
            </div>
          <% end %> 
        </div>
      </div>
    <% end %>
  </div>
</div>