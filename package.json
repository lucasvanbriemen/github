{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "github-gui",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "electron/main.cjs",
    "repository": "github:lucasvanbriemen/github",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "electron": "electron .",
        "electron:dev": "npx concurrently -c \"#93c5fd,#fdba74\" \"vite\" \"electron .\" --names='vite,electron'",
        "dist": "vite build && electron-builder --win",
        "dist:publish": "vite build && electron-builder --win --publish always"
    },
    "build": {
        "appId": "nl.ltvb.github-gui",
        "productName": "GitHub GUI",
        "protocols": [
            {
                "name": "GitHub GUI",
                "schemes": ["githubgui"]
            }
        ],
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "electron/**/*",
            "public/build/**/*",
            "public/images/**/*",
            "public/index.php",
            "public/favicon.ico",
            "resources/views/**/*",
            "app/**/*",
            "bootstrap/**/*",
            "config/**/*",
            "database/**/*",
            "routes/**/*",
            "storage/**/*",
            "vendor/**/*",
            "artisan",
            "composer.json",
            ".env"
        ],
        "win": {
            "target": "nsis",
            "icon": "electron/icon.png"
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "allowToChangeInstallationDirectory": false
        },
        "publish": {
            "provider": "github",
            "owner": "lucasvanbriemen",
            "repo": "github",
            "releaseType": "release"
        }
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^6.2.1",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "electron": "^35.7.5",
        "electron-builder": "^26.0.0",
        "laravel-vite-plugin": "^2.0.0",
        "sass-embedded": "^1.92.1",
        "svelte": "^5.40.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.4"
    },
    "dependencies": {
        "electron-updater": "^6.3.0",
        "@bytemd/plugin-gfm": "^1.22.0",
        "bytemd": "^1.22.0",
        "diff2html": "^3.4.52",
        "fast-glob": "^3.3.3",
        "github-markdown-css": "^5.8.1",
        "highlight.js": "^11.11.1",
        "marked": "^16.4.1",
        "shiki": "^3.12.2",
        "svelte-spa-router": "^4.0.1"
    }
}
