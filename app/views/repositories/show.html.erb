<% content_for :title, "#{@repository.name} · #{@repository.organization.name}" %>

<div class="repository-show">
  <header class="repository-header">
    <p class="organization"><%= @repository.organization.name %></p>
    <h1><%= @repository.name %></h1>
    <p class="description"><%= @repository.display_description %></p>
  </header>

  <% tabs = [
       { key: "all", label: "All", is_active: (params[:filter].blank? || params[:filter] == "all"), url: repository_path(organization_name: @repository.organization.name, repository_name: @repository.name) },
       { key: "issues", label: "Issues", is_active: (params[:filter] == "issues"), url: repository_path(organization_name: @repository.organization.name, repository_name: @repository.name, filter: "issues") },
       { key: "pull_requests", label: "Pull requests", is_active: (params[:filter] == "pull_requests"), url: repository_path(organization_name: @repository.organization.name, repository_name: @repository.name, filter: "pull_requests") }
     ] %>

  <div class="tabs">
    <nav>
      <% tabs.each do |tab| %>
        <div class="tab">
        <%= link_to tab[:url],
                    class: "tab #{'current disabled' if tab[:is_active]}" do %>
          <%= tab[:label] %>
        <% end %>
              </div>

      <% end %>
    </nav>
  </div>

  <% if @items.any? %>
    <ul class="items">
      <% @items.each do |item| %>
        <li class="item"><%= item.title %></li>
      <% end %>
    </ul>

    <div class="pagination">
      <%= paginate @items %>
    </div>
  <% else %>
    <p class="items items--empty">Nothing to show here yet.</p>
  <% end %>
</div>
